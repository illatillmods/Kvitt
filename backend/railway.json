{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "preDeployCommand": [
      "python -m alembic upgrade head"
    ],
    "startCommand": "sh -c 'python -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}'",
    "healthcheckPath": "/api/v1/ready",
    "healthcheckTimeout": 180
  }
}