KVITT_ENVIRONMENT=production
KVITT_APP_NAME=KVITT API
KVITT_APP_VERSION=0.1.0
KVITT_API_V1_PREFIX=/api/v1
KVITT_DEFAULT_ACCESS_TIER=free
KVITT_CORS_ORIGINS=["*"]
KVITT_AUTO_CREATE_TABLES=false
KVITT_REQUIRE_DB_READY=true
KVITT_OPENAI_CATEGORIZATION_ENABLED=true
KVITT_OPENAI_MODEL=gpt-4.1-mini
KVITT_OPENAI_TIMEOUT_SECONDS=8.0
# On Railway, set this in service variables if you want OpenAI-backed long-tail categorization.
KVITT_OPENAI_API_KEY=
KVITT_OPENAI_BASE_URL=https://api.openai.com/v1
# On Railway, set this from the attached PostgreSQL service variable.
# Example in Railway service variables: KVITT_DATABASE_URL=${{Postgres.DATABASE_URL}}
KVITT_DATABASE_URL=postgresql+psycopg://kvitt:change-me@localhost:5432/kvitt